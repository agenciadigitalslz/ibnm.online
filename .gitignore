# ==============================================================================
# .gitignore — SaaS Igrejas (PHP/MySQL)
# ==============================================================================

# ==============================================================================
# CREDENCIAIS E SEGURANÇA (CRÍTICO)
# ==============================================================================
# Arquivo de ambiente (Sprint 1 - 2026-02-09)
.env
.env.*
!.env.example

# Conexões antigas (removidas na Sprint 1)
# sistema/conexao.php  → Agora usa .env
# apiIgreja/conexao.php → Agora usa .env

# MCP Tools
mcp-mysql-local.json

# FTP Quota
.ftpquota

# Documentação sensível
MySQL.md

# Arquivos temporários do Windows
nul

# Chaves SSH (se houver)
*.pem
*.key
id_rsa*
.ssh/

# Certificados SSL
*.crt
*.cer
*.p12
*.pfx

# ==============================================================================
# LOGS E ARQUIVOS DE ERRO
# ==============================================================================
error_log
*.log
logs/
sistema/logs/
php_errors.log

# ==============================================================================
# BACKUPS E ARQUIVOS TEMPORÁRIOS
# ==============================================================================
*.zip
*.tar.gz
*.rar
*.bak
*.old
*.tmp
*.temp
*.swp
*.swo
*~
backup/
backups/

# Dumps de banco de dados (CRÍTICO)
*.sql
*.sql.gz
*.dump
*.dump.gz

# Exceto o schema oficial (permitir)
!SQL/novo_igreja.sql
!SQL/migrations/*.sql

# ==============================================================================
# IDEs E EDITORES
# ==============================================================================
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
.project
.settings/
*.code-workspace

# ==============================================================================
# CONFIGURAÇÕES DE IA/ASSISTENTES
# ==============================================================================
.claude/
.cursor/

# ==============================================================================
# CACHE E ARQUIVOS GERADOS
# ==============================================================================
cache/
tmp/
temp/
.cache/
*.cache

# ==============================================================================
# UPLOADS E ARQUIVOS DE USUÁRIO (grandes)
# ==============================================================================
sistema/img/uploads_temp/
sistema/painel-igreja/uploads_temp/
sistema/painel-admin/uploads_temp/

# ==============================================================================
# SISTEMA OPERACIONAL
# ==============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

