security_logs_*.csv
failed_logins_export_*.csv

# Relatórios de auditoria temporários
audit_report_*.pdf.tmp
security_report_*.html.tmp

# ==============================================================================
# DOCUMENTAÇÃO GERADA TEMPORÁRIA
# ==============================================================================
