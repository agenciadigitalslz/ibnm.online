# ==============================================================================
# .gitignore — SaaS Igrejas (PHP/MySQL)
# ==============================================================================

# ==============================================================================
# CREDENCIAIS E SEGURANÇA (CRÍTICO)
# ==============================================================================
.env
.env.*
!.env.example
sistema/conexao.php
**/conexao.php
mcp-mysql-local.json
.ftpquota
MySQL.md

# ==============================================================================
# LOGS E ARQUIVOS DE ERRO
# ==============================================================================
error_log
*.log
logs/
sistema/logs/
php_errors.log

# ==============================================================================
# BACKUPS E ARQUIVOS TEMPORÁRIOS
# ==============================================================================
*.zip
*.tar.gz
*.rar
*.bak
*.old
*.tmp
*.temp
*.swp
*.swo
*~
backup/
backups/

# ==============================================================================
# IDEs E EDITORES
# ==============================================================================
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
.project
.settings/
*.code-workspace

# ==============================================================================
# CONFIGURAÇÕES DE IA/ASSISTENTES
# ==============================================================================
.claude/
.cursor/

# ==============================================================================
# CACHE E ARQUIVOS GERADOS
# ==============================================================================
cache/
tmp/
temp/
.cache/
*.cache

# ==============================================================================
# UPLOADS E ARQUIVOS DE USUÁRIO (grandes)
# ==============================================================================
sistema/img/uploads_temp/
sistema/painel-igreja/uploads_temp/
sistema/painel-admin/uploads_temp/

# ==============================================================================
# SISTEMA OPERACIONAL
# ==============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ==============================================================================
# DIRETÓRIOS ESPECÍFICOS DO PROJETO
# ==============================================================================
SQL/
ibnm/

# ==============================================================================
# ARQUIVOS DE TESTE E DESENVOLVIMENTO
# ==============================================================================
test_*.php
*_test.php
debug_*.php
*.debug
phpinfo.php

# ==============================================================================
# DOCUMENTAÇÃO GERADA TEMPORÁRIA
# ==============================================================================
# (Nota: docs/ é versionado, apenas temporários são ignorados)
*.md.bak
*.md.tmp
