# ============================================================================
# IBNM.ONLINE - TEMPLATE DE CONFIGURAÇÕES DE AMBIENTE
# ============================================================================
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Preencha com suas configurações reais
# 3. NUNCA versione o arquivo .env no Git!
# ============================================================================

# ------------------------------------------------------------------------------
# BANCO DE DADOS
# ------------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nome_do_banco
DB_USER=usuario_mysql
DB_PASSWORD=senha_mysql_aqui
DB_CHARSET=utf8mb4

# ------------------------------------------------------------------------------
# URLS DO SISTEMA
# ------------------------------------------------------------------------------
# Deixe em branco para detecção automática ou configure manualmente:
# URL_SISTEMA_SITE=http://seusite.com/
# URL_SISTEMA=http://seusite.com/sistema/

# ------------------------------------------------------------------------------
# CONFIGURAÇÕES DO SISTEMA
# ------------------------------------------------------------------------------
NOME_SISTEMA=Nome da Sua Igreja
EMAIL_SUPER_ADM=seu_email@exemplo.com
TELEFONE_IGREJA=(00) 00000-0000
ENDERECO_IGREJA=Seu Endereço Completo

# ------------------------------------------------------------------------------
# AMBIENTE
# ------------------------------------------------------------------------------
APP_ENV=development
APP_DEBUG=true

# ------------------------------------------------------------------------------
# SEGURANÇA
# ------------------------------------------------------------------------------
# Gerar chave JWT (512 bits): php scripts/generate_jwt_secret.php
# Ou manualmente: openssl rand -base64 64
JWT_SECRET_KEY=

# Gerar chave de criptografia (256 bits): openssl rand -base64 32
ENCRYPTION_KEY=

# ------------------------------------------------------------------------------
# MCP TOOLS (Opcional)
# ------------------------------------------------------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=nome_do_banco
MYSQL_ALLOW_CREATE=true
MYSQL_ALLOW_UPDATE=true
MYSQL_ALLOW_DELETE=true
